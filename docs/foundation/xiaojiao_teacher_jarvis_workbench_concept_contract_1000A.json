  "core_concepts": [
    {
      "id": "unified_xiaojiao_agent",
      "en": "Unified Xiaojiao Agent",
      "zh": "统一小教智能体",
      "definition": "The single teacher work agent that understands intent, identifies active work, maintains Work State, coordinates panels, and selects Work Actions."
    },
    {
      "id": "agent_led_progressive_workspace",
      "en": "Agent-led Progressive Workspace",
      "zh": "小教主导的渐进式工作台",
      "definition": "A workspace that unfolds from the teacher task and Work State instead of exposing fixed module menus first."
    },
    {
      "id": "dynamic_work_panel",
      "en": "Dynamic Work Panel",
      "zh": "动态工作面板",
      "definition": "A task-aware view container whose fields and actions change by role, scope, task, missing information, artifacts, and review readiness."
    },
    {
      "id": "work_object",
      "en": "Work Object",
      "zh": "工作对象",
      "definition": "The business object the teacher is actually working on, such as a teaching work plan, weekly work graph, rubric, or classroom preparation package."
    },
    {
      "id": "work_action",
      "en": "Work Action",
      "zh": "工作动作",
      "definition": "An operation applied to a Work Object, such as CLARIFY, GENERATE, MODIFY, DERIVE, SYNC, REVIEW, CONFIRM, BLOCK, PREPARE_EXPORT, or RECORD."
    },
    {
      "id": "work_state",
      "en": "Work State",
      "zh": "工作状态",
      "definition": "The structured state that tracks goals, active objects, known fields, missing fields, generated candidates, work items, linked artifacts, and next actions."
    }
  ],
  "supporting_concepts": [
    {
      "id": "work_view_composer",
      "en": "Work View Composer",
      "zh": "工作视图组合器",
      "definition": "The layer that converts Work State into panel layout, panel priority, visible fields, available actions, and assistant surface placement."
    },
    {
      "id": "assistant_surface",
      "en": "Assistant Surface",
      "zh": "小教交互表层",
      "accepted_zh_aliases": [
        "小教表层",
        "助手表层",
        "小教交互表层",
        "助手交互表层"
      ],
      "definition": "The lightweight interaction layer for Xiaojiao suggestions, confirmations, mini dialogue, and work records."
    }
  ],
  "concept_relationship": [
    "Unified Xiaojiao Agent",
    "leads Agent-led Progressive Workspace",
    "organizes Dynamic Work Panel",
    "displays Work Object",
    "advances through Work Action",
    "updates Work State"
  ],
  "assistant_surface_states": [
    {
      "state": "collapsed",
      "definition": "Only the Xiaojiao entry is visible."
    },
    {
      "state": "suggestion_bar",
      "definition": "A compact current suggestion or next action is visible."
    },
    {
      "state": "mini_chat_overlay",
      "definition": "A temporary compact dialogue surface is visible for clarification or confirmation."
    },
    {
      "state": "work_record_drawer",
      "definition": "History and work trace are available without occupying the default main workspace."
    }
  ],
